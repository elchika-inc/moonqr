{
  "name": "@elchika-inc/moonqr-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "QR code scanner with camera support for moonqr",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "git+https://github.com/naoto24kawa/moonqr.git" },
  "keywords": ["qrcode", "scanner", "camera", "moonbit"],
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test:unit": "vitest run",
    "build": "tsup"
  },
  "dependencies": {
    "@elchika-inc/moonqr": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
